{
  "manifest_version": 3,
  "name": "AI Content Detector",
  "description": "Filters AI-generated content on YouTube",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "activeTab",
    "offscreen",
    "downloads"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://i.ytimg.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["layer1.js", "layer2.js", "feedback-ui.js", "layer3.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Content Detector"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
